# Configurações do MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin_password
MONGO_DB_NAME=clothing_db

# URI do MongoDB injetada na aplicação Spring Boot
# Formato: mongodb://USER:PASSWORD@HOST:PORT/DATABASE?authSource=admin
MONGO_URI=mongodb://admin:admin_password@mongodb:27017/clothing_db?authSource=admin